# Environment Variables Template
# Copy this to .env and fill in your actual API keys
# ⚠️  .env is in .gitignore and will NEVER be committed

# Google Maps Places API (must have VITE_ prefix — used in browser)
# Get key from: https://console.cloud.google.com
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# OpenRouter API Key (server-side ONLY — no VITE_ prefix)
# Get key from: https://openrouter.io/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# Backend auth secret — shared between server and frontend bundle
# Generate with: openssl rand -hex 32
VITE_API_SECRET=YOUR_RANDOM_SECRET_HERE

# Note: Jina Reader does NOT require an API key (it's free)
